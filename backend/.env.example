# ── Database ──
DATABASE_URL=postgresql+asyncpg://wealth_gainer:wealth_gainer@localhost:5432/wealth_gainer

# ── Application ──
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Trading ──
TRADING_MODE=manual

# ── API Keys (fill in with real values in .env) ──
